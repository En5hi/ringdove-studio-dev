---
import { SITE } from '../../lib/site';
---

<div class="frame-edge frame-top">
  <div class="wordmark">Rin<em>g</em>dove</div>
  <div
    class="section"
    id="section-name"
    set:html={SITE.hero.headline.replace(/\.<\/em>$/, '</em>')}
  >
  </div>
  <nav class="nav" aria-label="Primary">
    <a href="/#work">Work</a>
    <a href="/#studio">Studio</a>
    <a href="/#contact">Contact</a>
  </nav>
</div>

<style>
  .frame-edge {
    position: fixed;
    background: var(--bg);
    z-index: 100;
  }

  .frame-top {
    top: 0;
    left: 0;
    right: 0;
    height: var(--frame-w);
    border-bottom: 1px solid var(--rule);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 0 var(--frame-w);
  }

  .wordmark {
    font-family: var(--display);
    font-weight: 400;
    font-size: var(--frame-wordmark);
    letter-spacing: -0.005em;
    color: var(--ink);
    padding: 0 8px;
  }
  .wordmark :global(em) {
    font-weight: 400;
  }

  .section {
    font-family: var(--display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--frame-counter);
    color: var(--ink-soft);
    letter-spacing: 0.01em;
    text-align: center;
    transition: opacity 400ms ease;
    padding: 0 16px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 60vw;
  }

  .nav {
    display: flex;
    gap: 18px;
    justify-content: flex-end;
    padding: 0 8px;
  }
  .nav a {
    font-family: var(--body);
    font-size: var(--frame-nav);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-soft);
    font-weight: 400;
    transition: color 220ms ease;
  }
  .nav a:hover {
    color: var(--ink);
  }

  /* Corner ticks — 9×9 plus-mark register marks at the inner corners.
     z-index lifts them above sibling content (wordmark / nav) which would
     otherwise overlap the corner regions and mask the ticks. */
  .frame-top::before,
  .frame-top::after {
    content: '';
    position: absolute;
    z-index: 1;
    width: 9px;
    height: 9px;
    background:
      linear-gradient(var(--ink), var(--ink)) center / 100% 1px no-repeat,
      linear-gradient(var(--ink), var(--ink)) center / 1px 100% no-repeat;
  }
  .frame-top::before {
    top: calc(var(--frame-w) - 5px);
    left: calc(var(--frame-w) - 5px);
  }
  .frame-top::after {
    top: calc(var(--frame-w) - 5px);
    right: calc(var(--frame-w) - 5px);
  }

  @media (max-width: 880px) {
    .frame-top {
      padding: 0 var(--frame-w);
    }
    .wordmark {
      font-size: 14px;
      padding: 0 4px;
    }
    .section {
      display: none;
    }
    .nav {
      gap: 10px;
      padding: 0 4px;
    }
    .nav a {
      letter-spacing: 0.16em;
    }
  }
</style>
