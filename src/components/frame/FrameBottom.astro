---
import { SITE } from '../../lib/site';
---

<div class="frame-edge frame-bottom">
  <div class="l">{SITE.coords}</div>
  <div class="c" id="page-counter">Plate I / VI</div>
  <div class="r">{SITE.colophon}</div>
</div>

<style>
  .frame-edge {
    position: fixed;
    background: var(--bg);
    z-index: 100;
  }

  .frame-bottom {
    bottom: 0;
    left: 0;
    right: 0;
    height: var(--frame-w);
    border-top: 1px solid var(--rule);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 0 16px;
  }

  .l,
  .r {
    font-family: var(--body);
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-soft);
    font-weight: 400;
    padding: 0 8px;
  }
  .r {
    text-align: right;
  }

  .c {
    font-family: var(--display);
    font-style: italic;
    font-weight: 300;
    font-size: 13px;
    color: var(--ink-soft);
    letter-spacing: 0.01em;
    padding: 0 16px;
    transition: opacity 400ms ease;
  }

  /* Corner ticks at the bottom inner corners. */
  .frame-bottom::before,
  .frame-bottom::after {
    content: '';
    position: absolute;
    width: 9px;
    height: 9px;
    background:
      linear-gradient(var(--ink), var(--ink)) center / 100% 1px no-repeat,
      linear-gradient(var(--ink), var(--ink)) center / 1px 100% no-repeat;
  }
  .frame-bottom::before {
    bottom: calc(var(--frame-w) - 5px);
    left: calc(var(--frame-w) - 5px);
  }
  .frame-bottom::after {
    bottom: calc(var(--frame-w) - 5px);
    right: calc(var(--frame-w) - 5px);
  }

  @media (max-width: 880px) {
    .frame-bottom {
      padding: 0 8px;
    }
    .l,
    .r {
      font-size: 12px;
      letter-spacing: 0.16em;
      padding: 0 4px;
    }
    .c {
      font-size: 13px;
    }
  }
</style>
