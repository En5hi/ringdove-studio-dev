---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<div class:list={['image', 'img-lattice', className]}></div>

<style>
  .image {
    width: 100%;
    aspect-ratio: var(--work-aspect, 4 / 5);
    background: var(--bg-soft);
    border: 1px solid var(--rule-soft);
    position: relative;
    overflow: hidden;
    transition:
      transform 800ms cubic-bezier(0.2, 0.8, 0.2, 1),
      opacity 800ms cubic-bezier(0.2, 0.8, 0.2, 1),
      filter 800ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .image:hover {
    transform: scale(1.005);
  }

  .img-lattice {
    background:
      linear-gradient(
        180deg,
        transparent 49.5%,
        rgba(242, 236, 220, 0.18) 49.5%,
        rgba(242, 236, 220, 0.18) 50.5%,
        transparent 50.5%
      ),
      linear-gradient(
        90deg,
        transparent 33%,
        rgba(242, 236, 220, 0.18) 33%,
        rgba(242, 236, 220, 0.18) 33.5%,
        transparent 33.5%,
        transparent 66%,
        rgba(242, 236, 220, 0.18) 66%,
        rgba(242, 236, 220, 0.18) 66.5%,
        transparent 66.5%
      ),
      var(--bg-soft);
    position: relative;
  }
  .img-lattice::before {
    content: '';
    position: absolute;
    left: 33.5%;
    top: 50.5%;
    width: 32.5%;
    height: 32%;
    background: var(--ink);
    opacity: 0.4;
  }
  .img-lattice::after {
    content: '';
    position: absolute;
    right: 12%;
    top: 12%;
    width: 14%;
    height: 3px;
    background: var(--ink);
  }
</style>
