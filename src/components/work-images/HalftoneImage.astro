---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<div class:list={['image', 'img-halftone', className]}></div>

<style>
  .image {
    width: 100%;
    max-width: 480px;
    aspect-ratio: 4 / 5;
    background: var(--bg-soft);
    border: 1px solid var(--rule-soft);
    position: relative;
    overflow: hidden;
    transition:
      transform 800ms cubic-bezier(0.2, 0.8, 0.2, 1),
      opacity 800ms cubic-bezier(0.2, 0.8, 0.2, 1),
      filter 800ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .image:hover {
    transform: scale(1.005);
  }

  .img-halftone {
    background: var(--bg-soft);
    position: relative;
    overflow: hidden;
  }
  .img-halftone::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, var(--ink) 1.2px, transparent 1.6px);
    background-size: 11px 11px;
    opacity: 0.55;
    -webkit-mask-image: linear-gradient(180deg, black 0%, transparent 75%);
    mask-image: linear-gradient(180deg, black 0%, transparent 75%);
  }
  .img-halftone::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, var(--ink) 1.6px, transparent 2px);
    background-size: 18px 18px;
    opacity: 0.3;
    -webkit-mask-image: linear-gradient(180deg, transparent 50%, black 100%);
    mask-image: linear-gradient(180deg, transparent 50%, black 100%);
  }
</style>
