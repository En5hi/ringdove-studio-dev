---
interface Props {
  date?: string;
  class?: string;
}
const { date = 'April · 2025', class: className } = Astro.props;
---

<div class:list={['image', 'img-morrow', className]}>
  <span class="yr">{date}</span>
</div>

<style>
  .image {
    width: 100%;
    max-width: 480px;
    aspect-ratio: 4 / 5;
    background: var(--bg-soft);
    border: 1px solid var(--rule-soft);
    position: relative;
    overflow: hidden;
    transition:
      transform 800ms cubic-bezier(0.2, 0.8, 0.2, 1),
      opacity 800ms cubic-bezier(0.2, 0.8, 0.2, 1),
      filter 800ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .image:hover {
    transform: scale(1.005);
  }

  .img-morrow {
    background: var(--bg-soft);
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 14% 12%;
  }
  .img-morrow::before {
    content: '€7,420';
    position: absolute;
    left: 12%;
    top: 22%;
    font-family: var(--display);
    font-weight: 300;
    font-size: clamp(28px, 4.4vw, 48px);
    letter-spacing: -0.04em;
    color: var(--ink);
  }
  .img-morrow::after {
    content: '';
    position: absolute;
    left: 12%;
    right: 12%;
    bottom: 22%;
    height: 1px;
    background: linear-gradient(
      90deg,
      var(--ink) 0%,
      var(--ink) 38%,
      transparent 38%,
      transparent 50%,
      var(--ink-soft) 50%,
      var(--ink-soft) 78%,
      transparent 78%
    );
  }
  .yr {
    font-family: var(--display);
    font-style: italic;
    font-weight: 300;
    font-size: 13px;
    color: var(--ink-faint);
    margin-bottom: 4px;
  }
</style>
