---
/*
 * Hairline wireframe sketch of a discipline destination route. Renders
 * inline as SVG so strokes stay 1 device-pixel via non-scaling-stroke.
 *
 * Slides in from the outer viewport edge on parent .disc hover/focus.
 * Positioning + transition lives in StudioPlate.astro; this component
 * is purely the visual representation.
 *
 * Structure for each discipline reflects the actual destination route:
 *   /product → DisciplineHero + Lattice (image right) + Morrow (image left)
 *   /audio   → DisciplineHero + Spire (image left)  + Halftone (image right)
 */

interface Props {
  variant: 'product' | 'audio';
  side: 'left' | 'right';
}
const { variant, side } = Astro.props;

// First work plate's image-side per the actual content collection ordering.
const firstWorkSide: 'left' | 'right' = variant === 'product' ? 'right' : 'left';
const secondWorkSide: 'left' | 'right' = firstWorkSide === 'right' ? 'left' : 'right';
---

<svg
  class:list={['wireframe', `wireframe-${side}`]}
  viewBox="0 0 180 280"
  preserveAspectRatio="xMidYMid meet"
  aria-hidden="true"
  focusable="false"
>
  <g
    stroke="var(--rule)"
    stroke-width="1"
    fill="none"
    vector-effect="non-scaling-stroke"
  >
    {/* Discipline hero plate */}
    <rect x="6" y="6" width="168" height="76" />
    <line x1="14" y1="36" x2="118" y2="36" />
    <line x1="14" y1="48" x2="86" y2="48" />
    <line x1="14" y1="68" x2="166" y2="68" />

    {/* Work plate 1 */}
    <rect x="6" y="94" width="168" height="80" />
    {firstWorkSide === 'right' ? (
      <>
        <line x1="100" y1="94" x2="100" y2="174" />
        <line x1="14" y1="124" x2="86" y2="124" />
        <line x1="14" y1="134" x2="86" y2="134" />
        <line x1="14" y1="144" x2="64" y2="144" />
      </>
    ) : (
      <>
        <line x1="80" y1="94" x2="80" y2="174" />
        <line x1="94" y1="124" x2="166" y2="124" />
        <line x1="94" y1="134" x2="166" y2="134" />
        <line x1="94" y1="144" x2="144" y2="144" />
      </>
    )}

    {/* Work plate 2 (opposite layout to plate 1) */}
    <rect x="6" y="186" width="168" height="80" />
    {secondWorkSide === 'right' ? (
      <>
        <line x1="100" y1="186" x2="100" y2="266" />
        <line x1="14" y1="216" x2="86" y2="216" />
        <line x1="14" y1="226" x2="86" y2="226" />
        <line x1="14" y1="236" x2="64" y2="236" />
      </>
    ) : (
      <>
        <line x1="80" y1="186" x2="80" y2="266" />
        <line x1="94" y1="216" x2="166" y2="216" />
        <line x1="94" y1="226" x2="166" y2="226" />
        <line x1="94" y1="236" x2="144" y2="236" />
      </>
    )}
  </g>
</svg>

<style>
  .wireframe {
    position: absolute;
    top: 50%;
    width: 180px;
    height: 280px;
    pointer-events: none;
    opacity: 0;
    transition:
      opacity 480ms cubic-bezier(0.2, 0.8, 0.2, 1),
      transform 480ms cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: opacity, transform;
  }
  .wireframe-left {
    left: 0;
    transform: translate(calc(-100% - 240px), -50%);
  }
  .wireframe-right {
    right: 0;
    transform: translate(calc(100% + 240px), -50%);
  }

  @media (prefers-reduced-motion: reduce) {
    .wireframe {
      transition: opacity 0.001ms;
    }
  }
</style>
