<section
  class="plate statement"
  data-section="On the work"
  data-page="— / VI"
>
  <div class="block reveal-slow" data-reveal-blur="8" data-reveal-offset="16">
    <span class="kicker">On the work</span>
    <p class="prose">
      We work end to end on a small number of projects each year. The first
      month is conversation, sketching, and the design decisions that will
      load-bear later. The remaining months are <em>finishing</em> &mdash;
      the part most studios short-change. We show the work in progress when
      there&rsquo;s something useful to show, and not before.
    </p>
  </div>
</section>

<style>
  .plate.statement {
    min-height: calc(100vh - var(--frame-w) * 2);
    padding: 96px 56px;
    border-bottom: 1px solid var(--rule-soft);
    position: relative;
    display: grid;
    place-items: center;
  }

  .block {
    max-width: 880px;
    width: 100%;
  }

  .kicker {
    display: block;
    font-family: var(--body);
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-soft);
    font-weight: 500;
    margin-bottom: 32px;
  }

  /* Long-form prose set in display italic — the editorial register the brief
     calls for. Sized between the body face and the statement scale. */
  .prose {
    margin: 0;
    font-family: var(--display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(24px, 2.6vw, 36px);
    line-height: 1.36;
    letter-spacing: -0.005em;
    color: var(--ink);
    text-align: left;
  }
  .prose :global(em) {
    /* Inside an already-italic block, em swaps to roman for contrast — the
       same italic-as-emphasis rule, inverted to keep the device working. */
    font-style: normal;
    font-weight: 400;
    color: var(--ink);
  }

  @media (max-width: 880px) {
    .plate.statement {
      padding: 56px 20px;
    }
    .prose {
      font-size: clamp(20px, 5vw, 26px);
      line-height: 1.4;
    }
  }
</style>
