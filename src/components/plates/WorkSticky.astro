---
import type { CollectionEntry } from 'astro:content';
import { ROMAN } from '../../lib/site';
import SpireImage from '../work-images/SpireImage.astro';
import LatticeImage from '../work-images/LatticeImage.astro';
import MorrowImage from '../work-images/MorrowImage.astro';
import HalftoneImage from '../work-images/HalftoneImage.astro';

interface Props {
  works: CollectionEntry<'work'>[];
  /** Page total denominator after the slash (defaults to 'VI'). */
  pageTotal?: string;
}
const { works, pageTotal = 'VI' } = Astro.props;

const slides = works.map((w) => {
  const { titlePlain, image, order } = w.data;
  const num = ROMAN[order] ?? String(order);
  // Pages II / VI through V / VI on the homepage default — matches the
  // numbering the four WorkPlates emitted in v1.
  const pageNum = ROMAN[order + 1] ?? String(order + 1);
  return {
    work: w,
    image,
    sectionLabel: `${num}. Selected Work — ${titlePlain}`,
    pageLabel: `${pageNum} / ${pageTotal}`,
  };
});
---

<section
  class="work-sticky"
  id="work"
  data-section={slides[0]?.sectionLabel ?? ''}
  data-page={slides[0]?.pageLabel ?? ''}
  data-frame-skip
>
  <div class="track">
    <ol class="copy-track">
      {
        slides.map((s, i) => {
          const { title, pretitle, lede, summary, deliverables, term, status } = s.work.data;
          return (
            <li
              class="copy-slide"
              data-idx={i}
              data-section={s.sectionLabel}
              data-page={s.pageLabel}
              data-frame-skip
            >
              <div class="copy reveal">
                <span class="pretitle">{pretitle}</span>
                <h2 set:html={title} />
                <p class="lede" set:html={lede} />
                <p class="body" set:html={summary} />
                <dl class="meta">
                  <dt>Deliver</dt>
                  <dd>{deliverables.join(' · ')}</dd>
                  <dt>Term</dt>
                  <dd>{term}</dd>
                  <dt>Status</dt>
                  <dd set:html={status} />
                </dl>
              </div>
              <div class="inline-image" aria-hidden="true">
                {s.image === 'spire' && <SpireImage />}
                {s.image === 'lattice' && <LatticeImage />}
                {s.image === 'morrow' && <MorrowImage />}
                {s.image === 'halftone' && <HalftoneImage />}
              </div>
            </li>
          );
        })
      }
    </ol>

    <div class="stage" aria-hidden="true">
      <div class="img-stack">
        {
          slides.map((s, i) => (
            <div class="img-slot" data-idx={i} data-active={i === 0 ? 'true' : undefined}>
              {s.image === 'spire' && <SpireImage />}
              {s.image === 'lattice' && <LatticeImage />}
              {s.image === 'morrow' && <MorrowImage />}
              {s.image === 'halftone' && <HalftoneImage />}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  import '../../lib/work-sticky';
</script>

<style>
  .work-sticky {
    position: relative;
    border-bottom: 1px solid var(--rule-soft);
  }

  /* Two columns now (counter removed): copy on the left, sticky image on
     the right. Each copy slide is the height of the viewport content area
     so the slide centre lines up with the sticky image centre — that way
     the first and last project don't read mid-air. */
  .track {
    display: grid;
    grid-template-columns: minmax(0, 480px) minmax(360px, 1fr);
    gap: 96px;
    padding: 0 56px;
    max-width: 1320px;
    margin: 0 auto;
  }

  .copy-track {
    grid-column: 1;
    grid-row: 1;
    margin: 0;
    padding: 0;
    list-style: none;
    align-self: start;
  }
  .copy-slide {
    /* Match the viewport content area exactly so each project's copy
       centres against the sticky image. Anything shorter (e.g. 70vh)
       leaves the first/last project visually offset from the image. */
    min-height: calc(100vh - var(--frame-w) * 2);
    display: flex;
    align-items: center;
    transition:
      opacity 360ms cubic-bezier(0.2, 0.8, 0.2, 1),
      filter 360ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .copy-slide[data-inactive] {
    opacity: 0.18;
    filter: blur(2px);
  }
  .copy-slide .inline-image {
    /* Desktop renders the sticky image in column 2; the inline copy of the
       image only appears in the stacked mobile fallback. */
    display: none;
  }

  .copy {
    max-width: 440px;
    display: flex;
    flex-direction: column;
  }
  .pretitle {
    font-family: var(--body);
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-soft);
    font-weight: 500;
    margin-bottom: 24px;
  }
  h2 {
    font-family: var(--display);
    font-weight: 300;
    font-size: clamp(36px, 4.4vw, 64px);
    line-height: 0.98;
    letter-spacing: -0.025em;
    margin-bottom: 20px;
    color: var(--ink);
  }
  h2 :global(em) {
    font-weight: 400;
  }
  .lede {
    font-family: var(--display);
    font-style: italic;
    font-weight: 400;
    font-size: 19px;
    line-height: 1.42;
    color: var(--ink-soft);
    margin-bottom: 24px;
    letter-spacing: 0.005em;
  }
  .body {
    font-family: var(--body);
    font-weight: 400;
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink);
    margin-bottom: 32px;
  }
  /* Family stays Author inside the body paragraph — em uses Author italic
     so it doesn't switch to display in the middle of body type. */
  .body :global(em) {
    font-family: var(--body);
    font-style: italic;
    font-weight: 400;
    color: var(--ink);
  }
  .meta {
    padding-top: 20px;
    border-top: 1px solid var(--rule-soft);
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 8px 24px;
    font-family: var(--body);
    font-size: 12.5px;
    font-weight: 400;
  }
  .meta dt {
    color: var(--ink-soft);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 12px;
    font-weight: 500;
    padding-top: 2px;
  }
  .meta dd {
    color: var(--ink);
  }

  /* Sticky image stage — column 2. Images are stacked absolutely so a
     cross-fade can keep both images alive during the transition. */
  .stage {
    grid-column: 2;
    grid-row: 1;
    position: sticky;
    top: var(--frame-w);
    align-self: start;
    height: calc(100vh - var(--frame-w) * 2);
    display: flex;
    align-items: center;
    justify-content: center;
    --work-aspect: 1 / 1;
  }
  .img-stack {
    position: relative;
    width: 100%;
    max-width: 560px;
    aspect-ratio: 1 / 1;
  }
  .img-slot {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 360ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .img-slot[data-active] {
    opacity: 1;
  }
  .img-slot :global(.image) {
    width: 100%;
    height: 100%;
  }

  @media (prefers-reduced-motion: reduce) {
    .img-slot {
      transition: none;
    }
    .copy-slide {
      transition: none;
    }
    .copy-slide[data-inactive] {
      opacity: 1;
      filter: none;
    }
  }

  /* Mobile fallback — drop the sticky mechanics entirely. Each slide reads
     as a normal stacked plate with its image inline above the copy. */
  @media (max-width: 880px) {
    .work-sticky {
      --work-aspect: 4 / 5;
    }
    .track {
      display: block;
      padding: 0 20px;
      gap: 0;
    }
    .stage {
      display: none;
    }
    .copy-track {
      grid-column: auto;
    }
    .copy-slide {
      min-height: auto;
      padding: 40px 0;
      flex-direction: column;
      align-items: stretch;
      gap: 32px;
      border-bottom: 1px solid var(--rule-soft);
    }
    .copy-slide:last-child {
      border-bottom: none;
    }
    .copy-slide[data-inactive] {
      opacity: 1;
      filter: none;
    }
    .copy-slide .inline-image {
      display: block;
      order: -1;
      width: 100%;
      max-width: 360px;
      align-self: center;
    }
    .copy {
      max-width: 100%;
    }
  }
</style>
