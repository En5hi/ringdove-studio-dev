---
import { SITE } from '../../lib/site';
---

<section class="plate contact" id="contact" data-section="Contact" data-page="VI / VI">
  <div class="block reveal" data-reveal-blur="10" data-reveal-offset="20">
    <span class="kicker">Write</span>
    <a class="email" href={`mailto:${SITE.email}`}>{SITE.email}</a>
    <ul class="meta" aria-label="Studio details">
      <li>
        <span class="lbl">Located</span>
        <span class="val">{SITE.location}</span>
      </li>
      <li>
        <span class="lbl">Currently</span>
        <span class="val">
          {SITE.contact.currently.headline} <span class="sub">·</span>
          <em>{SITE.contact.currently.sub}</em>
        </span>
      </li>
      <li>
        <span class="lbl">Set in</span>
        <span class="val">Times &amp; Author <span class="sub">·</span> MMXXVI</span>
      </li>
    </ul>
  </div>
</section>

<style>
  .plate.contact {
    min-height: calc(100vh - var(--frame-w) * 2);
    padding: 96px 56px 80px;
    border-bottom: 1px solid var(--rule-soft);
    position: relative;
    display: grid;
    place-items: center;
  }

  .block {
    width: 100%;
    max-width: 1100px;
    text-align: center;
  }

  .kicker {
    display: block;
    font-family: var(--body);
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-soft);
    font-weight: 500;
    margin-bottom: 32px;
  }

  /* The single focal point — email at hero scale. Italic as the only
     emphasis device, matching the studio rule. */
  .email {
    display: inline-block;
    font-family: var(--display);
    font-weight: 200;
    font-style: italic;
    font-size: clamp(64px, 9.6vw, 168px);
    line-height: 0.96;
    letter-spacing: -0.035em;
    color: var(--ink);
    text-decoration: none;
    transition:
      color 220ms cubic-bezier(0.2, 0.8, 0.2, 1),
      letter-spacing 360ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .email:hover {
    color: var(--ink-soft);
    letter-spacing: -0.025em;
  }

  .meta {
    margin: 56px 0 0;
    padding: 28px 0 0;
    border-top: 1px solid var(--rule-soft);
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 32px;
    text-align: left;
  }
  .meta li {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .lbl {
    font-family: var(--body);
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-soft);
    font-weight: 500;
  }
  .val {
    font-family: var(--display);
    font-weight: 400;
    font-size: 17px;
    letter-spacing: -0.005em;
    line-height: 1.4;
    color: var(--ink);
  }
  .val :global(em) {
    color: var(--ink-soft);
    font-weight: 300;
  }
  .sub {
    color: var(--ink-faint);
    margin: 0 4px;
  }

  @media (max-width: 880px) {
    .plate.contact {
      padding: 56px 20px 40px;
    }
    .email {
      font-size: clamp(40px, 12vw, 64px);
    }
    .meta {
      grid-template-columns: 1fr;
      gap: 20px;
      margin-top: 40px;
    }
    .block {
      text-align: left;
    }
  }
</style>
