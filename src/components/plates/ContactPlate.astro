---
import { SITE } from '../../lib/site';
---

<section class="plate contact" id="contact" data-section="Contact" data-page="VI / VI">
  <div class="word" aria-hidden="true">Rin<em>g</em>dove.</div>
  <div class="info reveal">
    <div class="col">
      <h4>Write</h4>
      <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
      <p class="s">{SITE.contact.write.sub}</p>
    </div>
    <div class="col">
      <h4>Located</h4>
      <p>{SITE.location}</p>
      <p class="s">{SITE.contact.located.sub}</p>
    </div>
    <div class="col">
      <h4>Currently</h4>
      <p>{SITE.contact.currently.headline}</p>
      <p class="s">{SITE.contact.currently.sub}</p>
    </div>
  </div>
</section>

<style>
  .plate {
    min-height: calc(100vh - var(--frame-w) * 2);
    padding: 64px 56px;
    border-bottom: 1px solid var(--rule-soft);
    position: relative;
  }

  /* Layered layout — wordmark drops to the bottom edge, info card overlaps
     its lower portion. Both children share grid cell 1/1 so they stack. */
  .plate.contact {
    display: grid;
    grid-template-rows: 1fr;
    grid-template-columns: 1fr;
    padding: 64px 56px 0;
  }
  .word,
  .info {
    grid-row: 1;
    grid-column: 1;
  }

  .word {
    align-self: end;
    justify-self: stretch;
    font-family: var(--display);
    font-weight: 200;
    font-size: clamp(120px, 22vw, 420px);
    line-height: 0.82;
    letter-spacing: -0.045em;
    text-align: left;
    color: var(--ink);
    margin: 0;
    user-select: none;
    pointer-events: none;
  }
  .word :global(em) {
    font-weight: 300;
  }

  .info {
    align-self: end;
    position: relative;
    z-index: 1;
    margin-bottom: 16px;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 40px;
    padding-top: 24px;
    border-top: 1px solid var(--rule-soft);
    /* Keep the info card legible where it overlaps the wordmark. */
    background: linear-gradient(
      to bottom,
      rgba(10, 9, 7, 0) 0%,
      var(--bg) 24%,
      var(--bg) 100%
    );
  }

  .col h4 {
    font-family: var(--body);
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-soft);
    font-weight: 500;
    margin-bottom: 12px;
  }
  .col a,
  .col p {
    display: block;
    font-family: var(--display);
    font-weight: 400;
    font-size: 20px;
    letter-spacing: -0.012em;
    line-height: 1.4;
    transition: font-style 220ms ease;
  }
  .col a:hover {
    font-style: italic;
  }
  .col .s {
    font-family: var(--body);
    font-size: 12.5px;
    color: var(--ink-soft);
    margin-top: 4px;
    font-weight: 400;
  }

  @media (max-width: 880px) {
    /* Stack normally — overlap is illegible at small sizes. */
    .plate.contact {
      grid-template-rows: 1fr auto;
      align-items: center;
      padding: 40px 20px;
      gap: 32px;
    }
    .word,
    .info {
      grid-row: auto;
      grid-column: auto;
    }
    .word {
      align-self: center;
      justify-self: center;
      font-size: clamp(64px, 18vw, 120px);
      text-align: center;
      margin-bottom: 0;
    }
    .info {
      align-self: end;
      margin-bottom: 0;
      grid-template-columns: 1fr;
      gap: 24px;
      background: none;
    }
  }
</style>
